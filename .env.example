# Supabase — obtener desde: Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — obtener desde: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Kapso — WhatsApp — obtener desde: kapso.ai → Dashboard
KAPSO_API_KEY=your-kapso-api-key
KAPSO_PHONE_NUMBER_ID=your-phone-number-id
KAPSO_WEBHOOK_SECRET=your-webhook-secret

# Anthropic — Captura IA — obtener desde: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
